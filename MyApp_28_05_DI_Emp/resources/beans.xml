<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="
        http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">

	<!-- bean definitions here -->
	<bean id="d" class="com.app.Date">
		<constructor-arg name="dd" type="int" value="13" />
		<constructor-arg name="mm" type="int" value="04" />
		<constructor-arg name="yy" type="int" value="2024" />
	</bean>
	
	<bean id="emp" class="com.app.Employee" >
	<constructor-arg name="id" type="int" value="2004"/>
	<constructor-arg name="name" value="Ishwar"/>
	<constructor-arg name="salary" type="double" value="50356.24"/>
	<constructor-arg  ref="d" />
	</bean>



</beans>