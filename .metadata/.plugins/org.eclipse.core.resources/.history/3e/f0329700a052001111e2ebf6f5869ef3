<!DOCTYPE html>
<html>
<head>
<meta charset="ISO-8859-1">
<title>Insert title here</title>
</head>
<body>
	<h2>Registration Form</h2>
	<form action="register.html" method="get" name="regForm"
		onSubmit="return validate()">
		<table>
			<tr>
				<td>Enter Your First Name</td>
				<td><input type="text" name="fName"></td>
			</tr>
			<tr>
				<td>Enter Your Email</td>
				<td><input type="email" name="pEmail"></td>
			</tr>
			<tr>
				<td>Enter Your Password</td>
				<td><input type="password" name="pass"></td>
			</tr>
			<tr>
				<td>Gender</td>
				<td><input type="checkbox" name="male">Male</td>
				<td><input type="checkbox" name="female">Female</td>
			</tr>
			<tr>
				<td>Enter Your Age Group</td>
				<td><select name="age">
						<option value="select" selected="selected">select</option>
						<option value="16-18">16-18</option>
						<option value="19-20">19-20</option>
						<option value="20-22">20-22</option>
						<option value="22-25">22-25</option>
						<option value="26-30">26-30</option>
						<option value="31-35">31-35</option>
				</select></td>
			</tr>
			<tr>
				<td><input type="checkbox" name="terms"></td>
				<td>Agree Terms and Conditions</td>
			</tr>
			<tr>
				<td><input type="button" value="login"
					onclick="location.href='login.html'"></td>
				<td><input type="button" value="Register"></td>
			</tr>
		</table>
	</form>

</body>
</html>